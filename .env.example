# Neon Postgres connection strings (console.neon.tech -> project -> Connect)
# Copy this file to .env and fill in real values. Never commit .env.

# Pooled connection string (default; host contains "-pooler") — used by the
# app at runtime via drizzle-orm/neon-http.
DATABASE_URL=postgresql://user:password@host/dbname

# Direct (unpooled) connection string — toggle "Connection pooling" OFF in the
# Neon Connect widget to get this one. Used ONLY by drizzle-kit (drizzle.config.ts)
# for schema push/generate/migrate; migration tooling needs a stable, long-lived
# connection that PgBouncer (the pooled string) does not support.
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname
